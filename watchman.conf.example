# Watchman Configuration
# Edit these values for your setup.

# ── GhostDrive ──────────────────────────────────────────────

# Path to the virtual disk container
CONTAINER=/ghostdrive.bin

# Size in MB (only used by create_disk.sh, 6144 = 6GB)
CONTAINER_SIZE_MB=6144

# Where to temporarily mount the container for file transfer
MOUNT_POINT=/mnt/ghostdrive

# ── Archive ─────────────────────────────────────────────────

# Where videos are permanently stored
ARCHIVE_DIR=/home/watchman/archive

# ── USB Gadget ──────────────────────────────────────────────

# Kernel module for USB mass storage
GADGET_MODULE=g_mass_storage

# ── Timing ──────────────────────────────────────────────────

# Seconds to wait after last write before ingesting
SETTLE_TIME=120

# Minimum seconds between ingest cycles
MIN_INTERVAL=1800

# Seconds to ignore writes after the gadget reconnects
# (prevents Blink's post-reconnect filesystem activity from triggering
# a new cycle immediately)
RECONNECT_COOLDOWN=120

# ── Watchdog ────────────────────────────────────────────────

# Consecutive failures before attempting full USB reset
WATCHDOG_THRESHOLD=3

# ── Web Interface ───────────────────────────────────────────

WEB_HOST=0.0.0.0
WEB_PORT=5000

# ── Network Watchdog ─────────────────────────────────────────────────────────

# Set to "no" to disable without removing the service
NET_WATCHDOG_ENABLED=yes

# Host to ping to check connectivity
NET_WATCHDOG_HOST=8.8.8.8

# How long (seconds) connectivity must be lost before rebooting (default: 5 min)
NET_WATCHDOG_TIMEOUT=600

# How often (seconds) to check connectivity
NET_WATCHDOG_INTERVAL=300

# ── Notifications (Pushover) ─────────────────────────────────────────────────

# Set to "no" to disable notifications
NOTIFY_ENABLED=yes

# Pushover application API token (from https://pushover.net/apps)
PUSHOVER_TOKEN=your_app_token_here

# Pushover user key (from https://pushover.net)
PUSHOVER_USER=your_user_key_here
