[Unit]
Description=Watchman Network Watchdog
Documentation=https://github.com/renanfernandes/watchman
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
ExecStart=/opt/watchman/net-watchdog.sh
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=watchman-net

[Install]
WantedBy=multi-user.target
